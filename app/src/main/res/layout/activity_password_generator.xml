<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGeneratedPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="P@ssw0rd123"
        android:textSize="24sp"
        android:gravity="center"
        android:padding="24dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/password_length"/>
        <TextView
            android:id="@+id/tvLengthValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12"
            android:textStyle="bold"/>
    </LinearLayout>

    <SeekBar
        android:id="@+id/sbLength"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="32"
        android:progress="12"/>

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbSymbols"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/include_symbols"
        android:checked="true"/>

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbNumbers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/include_numbers"
        android:checked="true"/>

    <Button
        android:id="@+id/btnGenerateNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/generate_password"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/btnUsePassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_use_password"
        android:layout_marginTop="8dp"/>

</LinearLayout>
